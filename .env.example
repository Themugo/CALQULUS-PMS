# ============================================================
# RentFlow — Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase (required) ─────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# ── Demo controls (staging/demo only; keep false in production) ──
VITE_ENABLE_PUBLIC_DEMO=false
VITE_ENABLE_DEMO_SEED=false
VITE_DEMO_SEED_SECRET=

# ── Error tracking (optional but strongly recommended in production) ─
# Leave blank to disable Sentry. When set, the lazy loader pulls in the
# Sentry browser SDK at runtime and forwards errors logged via the
# shared errorLogger. Source maps are emitted as `hidden` so they can be
# uploaded to Sentry without shipping to end users.
#
#   1. Install:  npm i @sentry/browser
#   2. Set VITE_SENTRY_DSN below
#   3. Upload source maps in CI after `vite build`
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=production
VITE_APP_VERSION=

# ── Supabase Edge Function Secrets (set in Supabase Dashboard) ─
# These are NOT in the frontend — set them in:
# Supabase Dashboard → Edge Functions → Secrets
#
# SUPABASE_SERVICE_ROLE_KEY=   (auto-set by Supabase)
# RESEND_API_KEY=              Email delivery (resend.com)
# SENDGRID_API_KEY=            Email delivery (sendgrid.net)
# MPESA_CONSUMER_KEY=          Safaricom Daraja API
# MPESA_CONSUMER_SECRET=       Safaricom Daraja API
# MPESA_PASSKEY=               Safaricom STK Push passkey
# MPESA_SHORTCODE=             Paybill / Till number
# MPESA_CALLBACK_SECRET=       Webhook validation secret
# MPESA_ENV=production         or 'sandbox' for testing
# AT_API_KEY=                  Africa's Talking SMS
# SITE_URL=https://yourdomain.com
# DEMO_SECRET=                 Strong random secret for staging/demo seed only
# BOOTSTRAP_SECRET=            One-time webhost bootstrap secret
# STRIPE_SECRET_KEY=           Stripe API key (server-side only)
# STRIPE_WEBHOOK_SECRET=       Stripe webhook signing secret
# PAYSTACK_SECRET_KEY=         Paystack API key (if using Paystack)
