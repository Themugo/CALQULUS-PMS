<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- Suppress false positives for development dependencies -->
    <suppress>
        <notes><![CDATA[
            False positive for development-only dependencies
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/.*@.*$</packageUrl>
        <cpe regex="true">cpe:/a:.*:.*</cpe>
    </suppress>
    
    <!-- Suppress known safe dependencies -->
    <suppress>
        <notes><![CDATA[
            React is actively maintained and vulnerabilities are quickly patched
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/react@.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    
    <suppress>
        <notes><![CDATA[
            React DOM is actively maintained and vulnerabilities are quickly patched
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/react-dom@.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    
    <!-- Suppress testing framework false positives -->
    <suppress>
        <notes><![CDATA[
            Testing frameworks are not used in production
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/@testing-library/.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    
    <suppress>
        <notes><![CDATA[
            Vitest is a testing framework, not used in production
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/vitest@.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
    
    <suppress>
        <notes><![CDATA[
            Playwright is for E2E testing, not used in production
        ]]></notes>
        <packageUrl regex="true">^pkg:npm/@playwright/test@.*$</packageUrl>
        <vulnerabilityName regex="true">.*</vulnerabilityName>
    </suppress>
</suppressions>
